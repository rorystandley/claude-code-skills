{
  "permissions": {
    "allow": [
      "Bash(python3 *)",
      "Bash(pip3 install *)",
      "Bash(pip3 install)",
      "Bash(ls *)",
      "Bash(ls)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
